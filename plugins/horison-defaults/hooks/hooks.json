{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $PLUGIN_DIR/hooks/scripts/secret-detection.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $PLUGIN_DIR/hooks/scripts/auto-format.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
